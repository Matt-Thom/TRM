# =============================================================================
# Temper Risk Management (TRM) — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your local environment.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=db
DB_PORT=5432
DB_USER=trm
DB_PASSWORD=changeme
DB_NAME=trm_dev

# -----------------------------------------------------------------------------
# Redis
# Used as both the Celery broker and result backend.
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# JWT Authentication
# JWT_SECRET_KEY: A strong random secret used to sign tokens.
# JWT_ACCESS_TOKEN_TTL: Access token lifetime in seconds (default: 900 = 15 min).
# JWT_REFRESH_TOKEN_TTL: Refresh token lifetime in seconds (default: 604800 = 7 days).
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800

# -----------------------------------------------------------------------------
# Microsoft Entra ID (Azure AD)
# Used for SSO / OAuth2 authentication flows.
# -----------------------------------------------------------------------------
ENTRA_TENANT_ID=your-entra-tenant-id
ENTRA_CLIENT_ID=your-entra-client-id
ENTRA_CLIENT_SECRET=your-entra-client-secret

# -----------------------------------------------------------------------------
# Microsoft Graph API
# Used for reading user/group data from Entra ID.
# -----------------------------------------------------------------------------
GRAPH_API_ENDPOINT=https://graph.microsoft.com/v1.0
GRAPH_API_SCOPES=https://graph.microsoft.com/.default

# -----------------------------------------------------------------------------
# ConnectWise
# Used for PSA integration (tickets, companies, contacts, etc.).
# -----------------------------------------------------------------------------
CW_COMPANY_ID=your-cw-company-id
CW_PUBLIC_KEY=your-cw-public-key
CW_PRIVATE_KEY=your-cw-private-key
CW_CLIENT_ID=your-cw-client-id
CW_BASE_URL=https://api-na.myconnectwise.net/v4_6_release/apis/3.0

# -----------------------------------------------------------------------------
# SMTP / Email
# Used for transactional email (alerts, invitations, reports, etc.).
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com
